<?xml version="1.0" encoding="utf-8"?>
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!--
        Design: "SeedChart"
        • Three bullish candlestick bars rising left→right
        • A single sprouting seedling growing from the tallest candle
        • Minimalist layout, generous whitespace, 3-color palette:
            Teal:  #00D4A0  (rising candles, stem, leaves)
            Gold:  #F5C518  (candle body highlight, seed)
            White: #FFFFFF  (wick lines, subtle glow)
    -->

    <!-- ═══════════════════════════════════════════
         CANDLE 1 — left, short bullish
    ════════════════════════════════════════════ -->
    <!-- wick -->
    <path
        android:pathData="M32,68 L32,57"
        android:strokeColor="#80FFFFFF"
        android:strokeWidth="2"
        android:strokeLineCap="round"
        android:fillColor="@android:color/transparent"/>
    <!-- body -->
    <path android:pathData="M28,76 h8 a2,2 0 0 0 2,-2 v-14 a2,2 0 0 0 -2,-2 h-8 a2,2 0 0 0 -2,2 v14 a2,2 0 0 0 2,2 z">
        <aapt:attr xmlns:aapt="http://schemas.android.com/aapt" name="android:fillColor">
            <gradient
                android:type="linear"
                android:startX="26"
                android:startY="58"
                android:endX="38"
                android:endY="76">
                <item android:offset="0"   android:color="#FF00D4A0"/>
                <item android:offset="1"   android:color="#FF009E78"/>
            </gradient>
        </aapt:attr>
    </path>

    <!-- ═══════════════════════════════════════════
         CANDLE 2 — center, medium bullish
    ════════════════════════════════════════════ -->
    <!-- wick -->
    <path
        android:pathData="M54,76 L54,44"
        android:strokeColor="#80FFFFFF"
        android:strokeWidth="2"
        android:strokeLineCap="round"
        android:fillColor="@android:color/transparent"/>
    <!-- body -->
    <path android:pathData="M50,76 h8 a2,2 0 0 0 2,-2 v-24 a2,2 0 0 0 -2,-2 h-8 a2,2 0 0 0 -2,2 v24 a2,2 0 0 0 2,2 z">
        <aapt:attr xmlns:aapt="http://schemas.android.com/aapt" name="android:fillColor">
            <gradient
                android:type="linear"
                android:startX="48"
                android:startY="48"
                android:endX="60"
                android:endY="76">
                <item android:offset="0"   android:color="#FF00D4A0"/>
                <item android:offset="1"   android:color="#FF009E78"/>
            </gradient>
        </aapt:attr>
    </path>

    <!-- ═══════════════════════════════════════════
         CANDLE 3 — right, tall bullish (gold accent)
    ════════════════════════════════════════════ -->
    <!-- wick -->
    <path
        android:pathData="M76,76 L76,36"
        android:strokeColor="#80FFFFFF"
        android:strokeWidth="2"
        android:strokeLineCap="round"
        android:fillColor="@android:color/transparent"/>
    <!-- body -->
    <path android:pathData="M72,76 h8 a2,2 0 0 0 2,-2 v-30 a2,2 0 0 0 -2,-2 h-8 a2,2 0 0 0 -2,2 v30 a2,2 0 0 0 2,2 z">
        <aapt:attr xmlns:aapt="http://schemas.android.com/aapt" name="android:fillColor">
            <gradient
                android:type="linear"
                android:startX="70"
                android:startY="42"
                android:endX="82"
                android:endY="76">
                <item android:offset="0"   android:color="#FFF5C518"/>
                <item android:offset="1"   android:color="#FFD4A010"/>
            </gradient>
        </aapt:attr>
    </path>
    <!-- inner shine on tall candle -->
    <path
        android:pathData="M74,46 L74,66"
        android:strokeColor="#40FFFFFF"
        android:strokeWidth="1.5"
        android:strokeLineCap="round"
        android:fillColor="@android:color/transparent"/>

    <!-- ═══════════════════════════════════════════
         SEEDLING on top of candle 3
         Stem grows upward from top of candle wick
    ════════════════════════════════════════════ -->
    <!-- stem -->
    <path
        android:pathData="M76,36 L76,24"
        android:strokeColor="#FF00D4A0"
        android:strokeWidth="2.5"
        android:strokeLineCap="round"
        android:fillColor="@android:color/transparent"/>

    <!-- left leaf -->
    <path
        android:pathData="M76,30 C76,30 66,28 64,22 C64,22 72,20 76,26 Z"
        android:fillColor="#FF00D4A0"
        android:fillAlpha="0.95"/>

    <!-- right leaf (lighter teal) -->
    <path
        android:pathData="M76,26 C76,26 86,24 88,18 C88,18 80,16 76,22 Z"
        android:fillColor="#FF39E8C0"
        android:fillAlpha="0.95"/>

    <!-- tiny seed dot at stem base (gold) -->
    <path android:pathData="M76,36 m-3,1 a3,2 0 1 0 6,0 a3,2 0 1 0 -6,0"
        android:fillColor="#FFF5C518"/>

    <!-- ═══════════════════════════════════════════
         BASELINE / GROUND LINE
    ════════════════════════════════════════════ -->
    <path
        android:pathData="M20,78 L88,78"
        android:strokeColor="#40FFFFFF"
        android:strokeWidth="1"
        android:strokeLineCap="round"
        android:fillColor="@android:color/transparent"/>

</vector>
